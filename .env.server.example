PROJECT_ROOT=/home/ubuntu/crewai-it-department

# Network and service ports
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# Ollama runtime
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_AUTOSTART=true
OLLAMA_PULL_MODELS=true

# Role model mapping tuned for a 48 GB VRAM server
DEFAULT_MODEL=qwen2.5-coder:14b
PM_MODEL=qwen3:14b
BA_MODEL=qwen3:14b
BACKEND_MODEL=qwen2.5-coder:14b
FRONTEND_MODEL=qwen2.5-coder:14b
QC_MODEL=qwen3:8b

# Telegram integration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
START_TELEGRAM_BOT=false

# Optional smoke run at startup
RUN_SAMPLE_ON_BOOT=false
BOOT_PRODUCT_REQUEST=Build an internal leave management dashboard for employees and managers.
